<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My GitHub Page</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background: #f5f5f5;
      color: #333;
      text-align: center;
    }

    header {
      background: #24292e;
      color: white;
      padding: 40px 20px;
    }

    main {
      padding: 40px 20px;
    }

    a {
      color: #0366d6;
      text-decoration: none;
    }

    .card {
      background: white;
      max-width: 600px;
      margin: 20px auto;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
  </style>
</head>

<body>
  <header>
    <h1>Welcome to My Site</h1>
    <p>Hosted with GitHub Pages</p>
  </header>

  <main>
    <div class="card">
      <h2>Hello 👋</h2>
      <p>This is my first GitHub Pages website.</p>
      <p>Edit this file to customize your site.</p>
    </div>

    <p>
      Visit my repo:
      <a href="https://github.com/your-username/your-repo" target="_blank">
        GitHub Link
      </a>
    </p>
  </main>
</body>
</html>